NOTION_API_KEY=ntn_...
PORT=3000
DB_PATH=./dashboard.db
SESSIONS_DIR=~/.claude/projects/<project-slug>
PROJECT_DIR=/path/to/project
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# PROJECTS — JSON array of project configs.
# Each entry requires: id (unique key), name, projectDir, contextUrl, boardId.
PROJECTS=[{"id":"my-project","name":"My Project","projectDir":"/path/to/repo","contextUrl":"https://www.notion.so/<context-page-id>","boardId":"<notion-database-id>"}]

# Auto-review: set AUTO_REVIEW=false to disable ReviewOrchestrator.
# AUTO_REVIEW_CONCURRENCY controls how many PR reviews run in parallel (default: 1).
AUTO_REVIEW=true
AUTO_REVIEW_CONCURRENCY=1
