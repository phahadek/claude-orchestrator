*.db-wal
*.db-journal

# Claude Code / tool-generated directories — but keep tracked templates (.example)
.claude/*
!.claude/local-context.md.example
.claire/

# Skill caches (e.g. /groom loader output) — host-specific, never committed
.skill-cache/

# Dashboard process PID file (generated by start.ps1 / stop.ps1)
.dashboard.pids

# Local task backend file (per-project, copied from tasks.yaml.example)
/tasks.yaml

# Scratch commit message files — never tracked
.commit-msg
*.commit_msg
commit-msg.txt
commit_msg.txt
commit-msg.*
commit_msg.*

# Local-only baseline / analysis output (raw telemetry, never committed)
/session-efficiency-baseline-output/

# Windows installer build artifacts (generated by installers/windows/build.ps1)
installers/windows/payload/
installers/windows/dist/
