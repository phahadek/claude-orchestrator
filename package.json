{
  "name": "claude-orchestrator",
  "version": "1.0.0",
  "private": true,
  "description": "A local web dashboard for browsing, managing, and orchestrating Claude Code sessions.",
  "main": "index.js",
  "homepage": "https://github.com/phahadek/claude-orchestrator#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/phahadek/claude-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/phahadek/claude-orchestrator/issues"
  },
  "workspaces": [
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w packages/backend\" \"npm run dev -w packages/frontend\"",
    "build": "npm run build -w packages/frontend && npm run build -w packages/backend",
    "start": "node packages/backend/dist/server.js",
    "restart": "npx kill-port 3000 && npm run dev",
    "restart:backend": "npx kill-port 3000 && npm run dev -w packages/backend",
    "test": "echo \"Error: no test specified\" && exit 1",
    "scan:identifiers": "node scripts/scan-identifiers.mjs",
    "audit:licenses": "npx --yes license-checker --failOn 'GPL;AGPL'",
    "format": "prettier --write .",
    "lint": "eslint .",
    "start:win": "powershell -ExecutionPolicy Bypass -File start.ps1",
    "stop:win": "powershell -ExecutionPolicy Bypass -File stop.ps1",
    "restart:win": "powershell -ExecutionPolicy Bypass -File restart.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "concurrently": "^8.0.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.24.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "agent",
    "dashboard",
    "orchestrator"
  ],
  "author": "Pedro Hadek <83268694+phahadek@users.noreply.github.com>",
  "license": "MIT",
  "type": "commonjs"
}
