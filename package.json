{
  "name": "claude-dashboard",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "main": "index.js",
  "workspaces": ["packages/backend", "packages/frontend"],
  "scripts": {
    "dev": "concurrently \"npm run dev -w packages/backend\" \"npm run dev -w packages/frontend\"",
    "build": "npm run build -w packages/frontend && npm run build -w packages/backend",
    "start": "node packages/backend/dist/server.js",
    "restart": "npx kill-port 3000 && npm run dev",
    "restart:backend": "npx kill-port 3000 && npm run dev -w packages/backend",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start:win": "powershell -ExecutionPolicy Bypass -File start.ps1",
    "stop:win": "powershell -ExecutionPolicy Bypass -File stop.ps1",
    "restart:win": "powershell -ExecutionPolicy Bypass -File restart.ps1"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "kill-port": "^2.0.1"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs"
}
